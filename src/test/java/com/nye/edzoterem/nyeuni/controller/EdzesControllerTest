package com.nye.edzoterem.nyeuni.controller;

import com.nye.edzoterem.nyeuni.dto.edzes.EdzesRequestDto;
import com.nye.edzoterem.nyeuni.dto.edzes.EdzesResponseDto;
import com.nye.edzoterem.nyeuni.service.EdzesService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.http.HttpStatus;

import java.util.List;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class EdzesControllerTest {

    @Mock
    private EdzesService edzesService;

    @InjectMocks
    private EdzesController edzesController;

    private EdzesRequestDto requestDto;
    private EdzesResponseDto responseDto;

    @BeforeEach
    void setUp() {
        requestDto = EdzesRequestDto.builder()
                .name("Fitness edzés")
                .edzoName("John Doe")
                .build();

        responseDto = EdzesResponseDto.builder()
                .id(1L)
                .name("Fitness edzés")
                .edzoName("John Doe")
                .build();
    }

    @Test
    void createEdzesResponse_ShouldReturnResponseDto() {
        when(edzesService.createEdzes(requestDto)).thenReturn(responseDto);

        EdzesResponseDto result = edzesController.createEdzesResponse(requestDto);

        assertThat(result).isNotNull();
        assertThat(result.getId()).isEqualTo(1L);
        assertThat(result.getName()).isEqualTo("Fitness edzés");
        verify(edzesService, times(1)).createEdzes(requestDto);
    }

    @Test
    void getAllEdzesek_ShouldReturnListOfResponseDto() {
        when(edzesService.getAllEdzesek()).thenReturn(List.of(responseDto));

        List<EdzesResponseDto> result = edzesController.getAllEdzesek();

        assertThat(result).hasSize(1);
        assertThat(result.get(0).getId()).isEqualTo(1L);
        verify(edzesService, times(1)).getAllEdzesek();
    }

    @Test
    void getEdzesById_ShouldReturnResponseDto() {
        when(edzesService.getEdzesById(1L)).thenReturn(responseDto);

        EdzesResponseDto result = edzesController.getEdzesById(1L);

        assertThat(result).isNotNull();
        assertThat(result.getId()).isEqualTo(1L);
        verify(edzesService, times(1)).getEdzesById(1L);
    }

    @Test
    void updateEdzesResponse_ShouldReturnUpdatedResponseDto() {
        when(edzesService.updateEdzes(1L, requestDto)).thenReturn(responseDto);

        EdzesResponseDto result = edzesController.updateEdzesResponse(1L, requestDto);

        assertThat(result).isNotNull();
        assertThat(result.getId()).isEqualTo(1L);
        verify(edzesService, times(1)).updateEdzes(1L, requestDto);
    }

    @Test
    void deleteEdzes_ShouldCallService() {
        doNothing().when(edzesService).deleteEdzes(1L);

        edzesController.deleteEdzes(1L);

        verify(edzesService, times(1)).deleteEdzes(1L);
    }

    @Test
    void hello_ShouldReturnWorkingMessage() {
        String result = edzesController.hello();

        assertThat(result).isEqualTo("API is working!");
    }
}