package com.nye.edzoterem.nyeuni.service;

import com.nye.edzoterem.nyeuni.dto.edzes.EdzesRequestDto;
import com.nye.edzoterem.nyeuni.dto.edzes.EdzesResponseDto;
import com.nye.edzoterem.nyeuni.entity.Edzes;
import com.nye.edzoterem.nyeuni.entity.exception.ResourceNotFoundException;
import com.nye.edzoterem.nyeuni.repository.EdzesRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.List;
import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class EdzesServiceTest {

    @Mock
    private EdzesRepository edzesRepository;

    @InjectMocks
    private EdzesService edzesService;

    private Edzes edzes;
    private EdzesRequestDto requestDto;
    private EdzesResponseDto responseDto;

    @BeforeEach
    void setUp() {
        edzes = Edzes.builder()
                .id(1L)
                .name("Fitness edzés")
                .edzoName("John Doe")
                .build();

        requestDto = EdzesRequestDto.builder()
                .name("Fitness edzés")
                .edzoName("John Doe")
                .build();

        responseDto = EdzesResponseDto.builder()
                .id(1L)
                .name("Fitness edzés")
                .edzoName("John Doe")
                .build();
    }

    @Test
    void createEdzes_ShouldReturnResponseDto_WhenSuccess() {
        when(edzesRepository.save(any(Edzes.class))).thenReturn(edzes);

        EdzesResponseDto result = edzesService.createEdzes(requestDto);

        assertThat(result).isNotNull();
        assertThat(result.getId()).isEqualTo(1L);
        assertThat(result.getName()).isEqualTo("Fitness edzés");
        assertThat(result.getEdzoName()).isEqualTo("John Doe");
        verify(edzesRepository, times(1)).save(any(Edzes.class));
    }

    @Test
    void getAllEdzesek_ShouldReturnListOfResponseDto_WhenSuccess() {
        when(edzesRepository.findAll()).thenReturn(List.of(edzes));

        List<EdzesResponseDto> result = edzesService.getAllEdzesek();

        assertThat(result).hasSize(1);
        assertThat(result.get(0).getId()).isEqualTo(1L);
        assertThat(result.get(0).getName()).isEqualTo("Fitness edzés");
        verify(edzesRepository, times(1)).findAll();
    }

    @Test
    void getAllEdzesek_ShouldReturnEmptyList_WhenNoEdzesExists() {
        when(edzesRepository.findAll()).thenReturn(List.of());

        List<EdzesResponseDto> result = edzesService.getAllEdzesek();

        assertThat(result).isEmpty();
        verify(edzesRepository, times(1)).findAll();
    }

    @Test
    void getEdzesById_ShouldReturnResponseDto_WhenEdzesExists() {
        when(edzesRepository.findById(1L)).thenReturn(Optional.of(edzes));

        EdzesResponseDto result = edzesService.getEdzesById(1L);

        assertThat(result).isNotNull();
        assertThat(result.getId()).isEqualTo(1L);
        assertThat(result.getName()).isEqualTo("Fitness edzés");
        verify(edzesRepository, times(1)).findById(1L);
    }

    @Test
    void getEdzesById_ShouldThrowResourceNotFoundException_WhenEdzesNotExists() {
        when(edzesRepository.findById(99L)).thenReturn(Optional.empty());

        assertThatThrownBy(() -> edzesService.getEdzesById(99L))
                .isInstanceOf(ResourceNotFoundException.class)
                .hasMessageContaining("Edzes not found by id: 99");
        verify(edzesRepository, times(1)).findById(99L);
    }

    @Test
    void updateEdzes_ShouldReturnUpdatedResponseDto_WhenEdzesExists() {
        EdzesRequestDto updateRequest = EdzesRequestDto.builder()
                .name("Yoga edzés")
                .edzoName("Jane Smith")
                .build();

        Edzes updatedEdzes = Edzes.builder()
                .id(1L)
                .name("Yoga edzés")
                .edzoName("Jane Smith")
                .build();

        when(edzesRepository.findById(1L)).thenReturn(Optional.of(edzes));
        when(edzesRepository.save(any(Edzes.class))).thenReturn(updatedEdzes);

        EdzesResponseDto result = edzesService.updateEdzes(1L, updateRequest);

        assertThat(result).isNotNull();
        assertThat(result.getName()).isEqualTo("Yoga edzés");
        assertThat(result.getEdzoName()).isEqualTo("Jane Smith");
        verify(edzesRepository, times(1)).findById(1L);
        verify(edzesRepository, times(1)).save(any(Edzes.class));
    }

    @Test
    void updateEdzes_ShouldThrowResourceNotFoundException_WhenEdzesNotExists() {
        EdzesRequestDto updateRequest = EdzesRequestDto.builder()
                .name("Yoga edzés")
                .edzoName("Jane Smith")
                .build();

        when(edzesRepository.findById(99L)).thenReturn(Optional.empty());

        assertThatThrownBy(() -> edzesService.updateEdzes(99L, updateRequest))
                .isInstanceOf(ResourceNotFoundException.class)
                .hasMessageContaining("Edzes not found by id: 99");
        verify(edzesRepository, times(1)).findById(99L);
        verify(edzesRepository, never()).save(any(Edzes.class));
    }

    @Test
    void deleteEdzes_ShouldCallRepositoryDelete_WhenEdzesExists() {
        doNothing().when(edzesRepository).deleteById(1L);

        edzesService.deleteEdzes(1L);

        verify(edzesRepository, times(1)).deleteById(1L);
    }
}