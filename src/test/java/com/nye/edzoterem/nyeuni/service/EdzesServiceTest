package com.nye.edzoterem.nyeuni.service;

import com.nye.edzoterem.nyeuni.dto.edzes.EdzesRequestDto;
import com.nye.edzoterem.nyeuni.dto.edzes.EdzesResponseDto;
import com.nye.edzoterem.nyeuni.entity.Edzes;
import com.nye.edzoterem.nyeuni.entity.exception.ResourceNotFoundException;
import com.nye.edzoterem.nyeuni.repository.EdzesRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.List;
import java.util.Optional;

import static org.assertj.core.api.Assertions.assertThat;
import static org.assertj.core.api.Assertions.assertThatThrownBy;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;

@ExtendWith(MockitoExtension.class)
class EdzesServiceTest {

    @Mock
    private EdzesRepository edzesRepository;

    @InjectMocks
    private EdzesService edzesService;

    private EdzesRequestDto requestDto;
    private Edzes edzes;

    @BeforeEach
    void setUp() {
        requestDto = EdzesRequestDto.builder()
                .name("Kardió edzés")
                .edzoName("Kiss Péter")
                .build();

        edzes = Edzes.builder()
                .id(1L)
                .name("Kardió edzés")
                .edzoName("Kiss Péter")
                .build();
    }

    @Test
    void createEdzes_ShouldReturnEdzesResponseDto() {
        when(edzesRepository.save(any(Edzes.class))).thenReturn(edzes);

        EdzesResponseDto response = edzesService.createEdzes(requestDto);

        assertThat(response).isNotNull();
        assertThat(response.getId()).isEqualTo(1L);
        assertThat(response.getName()).isEqualTo("Kardió edzés");
        assertThat(response.getEdzoName()).isEqualTo("Kiss Péter");

        verify(edzesRepository, times(1)).save(any(Edzes.class));
    }

    @Test
    void getAllEdzesek_ShouldReturnList() {
        List<Edzes> edzesList = List.of(edzes);
        when(edzesRepository.findAll()).thenReturn(edzesList);

        List<EdzesResponseDto> response = edzesService.getAllEdzesek();

        assertThat(response).hasSize(1);
        assertThat(response.get(0).getName()).isEqualTo("Kardió edzés");

        verify(edzesRepository, times(1)).findAll();
    }

    @Test
    void getEdzesById_WhenExists_ShouldReturn() {
        when(edzesRepository.findById(1L)).thenReturn(Optional.of(edzes));

        EdzesResponseDto response = edzesService.getEdzesById(1L);

        assertThat(response.getId()).isEqualTo(1L);
        verify(edzesRepository, times(1)).findById(1L);
    }

    @Test
    void getEdzesById_WhenNotFound_ShouldThrowException() {
        when(edzesRepository.findById(99L)).thenReturn(Optional.empty());

        assertThatThrownBy(() -> edzesService.getEdzesById(99L))
                .isInstanceOf(ResourceNotFoundException.class)
                .hasMessageContaining("Edzes not found by id: 99");
    }

    @Test
    void updateEdzes_WhenExists_ShouldUpdate() {
        EdzesRequestDto updateRequest = EdzesRequestDto.builder()
                .name("Erősítő edzés")
                .edzoName("Nagy Anna")
                .build();

        Edzes updatedEdzes = Edzes.builder()
                .id(1L)
                .name("Erősítő edzés")
                .edzoName("Nagy Anna")
                .build();

        when(edzesRepository.findById(1L)).thenReturn(Optional.of(edzes));
        when(edzesRepository.save(any(Edzes.class))).thenReturn(updatedEdzes);

        EdzesResponseDto response = edzesService.updateEdzes(1L, updateRequest);

        assertThat(response.getName()).isEqualTo("Erősítő edzés");
        assertThat(response.getEdzoName()).isEqualTo("Nagy Anna");
    }

    @Test
    void deleteEdzes_ShouldDelete() {
        doNothing().when(edzesRepository).deleteById(1L);

        edzesService.deleteEdzes(1L);

        verify(edzesRepository, times(1)).deleteById(1L);
    }
}